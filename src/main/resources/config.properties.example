# Database Configuration
db.url=jdbc:mysql://localhost:3306/JudgeSystem?useUnicode=true&characterEncoding=UTF-8&serverTimezone=UTC
db.username=root
db.password=123
db.driver=com.mysql.cj.jdbc.Driver

# AI API Configuration (Google Gemini)
# Get your API key from: https://aistudio.google.com/app/apikey
ai.api.key=YOUR_GEMINI_API_KEY_HERE
ai.api.url=https://generativelanguage.googleapis.com/v1beta/models/
ai.model=gemini-2.5-flash

# File Storage
file.root.dir=./JudgeSystemData
file.problems.dir=${file.root.dir}/Problems
file.testcases.dir=${file.root.dir}/Testcases
file.submissions.dir=${file.root.dir}/Submissions
file.samples.dir=${file.root.dir}/Samples

# Judge Configuration
judge.default.timelimit=2000
judge.default.memorylimit=256
judge.compiler.java=javac
judge.compiler.cpp=g++
judge.runner.java=java
